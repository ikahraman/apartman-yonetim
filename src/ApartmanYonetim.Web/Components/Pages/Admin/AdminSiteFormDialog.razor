@inject IFirmRegistrationService FirmService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Temel Bilgiler</MudText>
            <MudSelect @bind-Value="_firmSlug" Label="Firma" Required="true" Variant="Variant.Outlined">
                @foreach (var f in Firms)
                {
                    <MudSelectItem Value="@f.Slug">@f.Name</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_name" Label="Site Adı" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_slug" Label="Slug" Required="true" Variant="Variant.Outlined" />
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudTextField @bind-Value="_city" Label="Şehir" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_unitCount" Label="Daire Sayısı" Variant="Variant.Outlined" Min="1" />
                </MudItem>
            </MudGrid>
            <MudTextField @bind-Value="_address" Label="Adres" Variant="Variant.Outlined" Lines="2" />
            <MudDivider Class="my-1" />
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Sözleşme Bilgileri</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_contractStartDate" Label="Sözleşme Başlangıç" Variant="Variant.Outlined" DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_contractEndDate" Label="Sözleşme Bitiş" Variant="Variant.Outlined" DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
            </MudGrid>
            <MudNumericField @bind-Value="_monthlyManagementFee" Label="Aylık Yönetim Ücreti (₺)" Variant="Variant.Outlined" Min="0" Format="N0" />
            <MudTextField @bind-Value="_contractNotes" Label="Sözleşme Notları" Variant="Variant.Outlined" Lines="3" />
            @if (_error is not null) { <MudAlert Severity="Severity.Error">@_error</MudAlert> }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="_busy">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Kaydet
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<FirmRegDto> Firms { get; set; } = [];

    private string _firmSlug = "";
    private string _name = "";
    private string _slug = "";
    private string? _city;
    private string? _address;
    private int _unitCount = 1;
    private DateTime? _contractStartDate;
    private DateTime? _contractEndDate;
    private decimal? _monthlyManagementFee;
    private string? _contractNotes;
    private string? _error;
    private bool _busy;

    protected override void OnParametersSet()
    {
        if (Firms.Any()) _firmSlug = Firms[0].Slug;
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_firmSlug))
        { _error = "Firma ve site adı zorunludur."; return; }
        _busy = true; _error = null;
        try
        {
            var cmd = new SiteCommand(
                Guid.Empty, _name.Trim(), _slug.Trim().ToLower(), _address, _city, _unitCount,
                _contractStartDate.HasValue ? DateOnly.FromDateTime(_contractStartDate.Value) : null,
                _contractEndDate.HasValue ? DateOnly.FromDateTime(_contractEndDate.Value) : null,
                _monthlyManagementFee, _contractNotes);
            await FirmService.CreateSiteForFirmAsync(_firmSlug, cmd);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
