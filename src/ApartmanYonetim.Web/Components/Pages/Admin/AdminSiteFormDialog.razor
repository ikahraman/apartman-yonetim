@inject IFirmRegistrationService FirmService
@inject IFirmSubscriptionService SubService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Temel Bilgiler</MudText>
            <MudSelect Value="_firmSlug" Label="Firma" Required="true" Variant="Variant.Outlined"
                       ValueChanged="@((string v) => OnFirmChanged(v))">
                @foreach (var f in Firms)
                {
                    <MudSelectItem Value="@f.Slug">@f.Name</MudSelectItem>
                }
            </MudSelect>

            @if (_limitBlocked)
            {
                <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Block">
                    <strong>Paket Limiti Doldu!</strong> Bu firma mevcut paketinde en fazla <strong>@_limitMax</strong> site yönetebilir.
                    Şu anda <strong>@_limitCurrent</strong> aktif sitesi var. Yeni site eklemek için paketi yükseltin.
                </MudAlert>
            }
            else if (_limitWarning)
            {
                <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Warning">
                    Bu firmanın <strong>@_limitCurrent / @_limitMax</strong> site kullanıyor. Paket limitine yaklaşıldı.
                </MudAlert>
            }
            <MudTextField @bind-Value="_name" Label="Site Adı" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_slug" Label="Slug" Required="true" Variant="Variant.Outlined" />
            <MudSelect @bind-Value="_siteType" Label="Site Tipi" Variant="Variant.Outlined">
                <MudSelectItem Value="SiteType.Apartman">Apartman (tek bina)</MudSelectItem>
                <MudSelectItem Value="SiteType.Site">Site (çok bloklu)</MudSelectItem>
                <MudSelectItem Value="SiteType.TopluYapi">Toplu Yapı (KMK 66-72)</MudSelectItem>
            </MudSelect>

            @if (_siteType == SiteType.Apartman)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_city" Label="Şehir" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="_unitCount" Label="Daire Sayısı" Variant="Variant.Outlined" Min="1"
                                         HelperText="Daireler otomatik oluşturulur" />
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_city" Label="Şehir" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                <MudAlert Severity="Severity.Info" Dense="true">
                    @(_siteType == SiteType.TopluYapi
                        ? "Toplu Yapı: Kayıt sonrası kısım ve blok yapısını tanımlayın, ardından daireler blok bazında girilir."
                        : "Site: Kayıt sonrası blokları tanımlayın, ardından daireler blok bazında girilir.")
                </MudAlert>
            }

            <MudTextField @bind-Value="_address" Label="Adres" Variant="Variant.Outlined" Lines="2" />
            <MudDivider Class="my-1" />
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Sözleşme Bilgileri</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_contractStartDate" Label="Sözleşme Başlangıç" Variant="Variant.Outlined" DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_contractEndDate" Label="Sözleşme Bitiş" Variant="Variant.Outlined" DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
            </MudGrid>
            <MudNumericField @bind-Value="_monthlyManagementFee" Label="Aylık Yönetim Ücreti (₺)" Variant="Variant.Outlined" Min="0" Format="N0" />
            <MudTextField @bind-Value="_contractNotes" Label="Sözleşme Notları" Variant="Variant.Outlined" Lines="3" />
            @if (_error is not null) { <MudAlert Severity="Severity.Error">@_error</MudAlert> }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="_busy">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            @(_siteType == SiteType.Apartman ? "Kaydet" : "Kaydet ve Yapıyı Düzenle →")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<FirmRegDto> Firms { get; set; } = [];

    private string _firmSlug = "";
    private string _name = "";
    private string _slug = "";
    private SiteType _siteType = SiteType.Site;
    private string? _city;
    private string? _address;
    private int _unitCount = 10;
    private DateTime? _contractStartDate;
    private DateTime? _contractEndDate;
    private decimal? _monthlyManagementFee;
    private string? _contractNotes;
    private string? _error;
    private bool _busy;

    private bool _limitBlocked;
    private bool _limitWarning;
    private int _limitCurrent;
    private int? _limitMax;

    protected override async Task OnParametersSetAsync()
    {
        if (Firms.Any()) await OnFirmChanged(Firms[0].Slug);
    }

    private async Task OnFirmChanged(string slug)
    {
        _firmSlug = slug;
        _limitBlocked = false; _limitWarning = false;
        if (string.IsNullOrEmpty(slug)) return;
        var (allowed, current, max) = await SubService.CheckSiteLimitAsync(slug);
        _limitCurrent = current; _limitMax = max;
        _limitBlocked = !allowed;
        _limitWarning = allowed && max.HasValue && current >= max.Value - 1;
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_firmSlug))
        { _error = "Firma ve site adı zorunludur."; return; }
        if (_limitBlocked) { _error = "Bu firma paket limitine ulaştı. Yeni site eklenemiyor."; return; }
        _busy = true; _error = null;
        try
        {
            var unitCount = _siteType == SiteType.Apartman ? _unitCount : 0;
            var cmd = new SiteCommand(
                Guid.Empty, _name.Trim(), _slug.Trim().ToLower(), _address, _city, unitCount,
                _contractStartDate.HasValue ? DateOnly.FromDateTime(_contractStartDate.Value) : null,
                _contractEndDate.HasValue ? DateOnly.FromDateTime(_contractEndDate.Value) : null,
                _monthlyManagementFee, _contractNotes, _siteType);
            var created = await FirmService.CreateSiteForFirmAsync(_firmSlug, cmd);
            MudDialog.Close(DialogResult.Ok(created));
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
