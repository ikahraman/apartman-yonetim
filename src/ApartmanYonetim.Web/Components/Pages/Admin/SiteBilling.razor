@page "/admin/site-faturalama"
@attribute [Authorize(Roles = "SuperAdmin")]
@inject ISiteObligationService ObligationService
@inject ISnackbar Snackbar

<PageTitle>Site Faturalama</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:700">Site Faturalama Yönetimi</MudText>

    <!-- Fiyat Kademeleri -->
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600">Fiyat Kademeleri (Daire Sayısına Göre)</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddTier">
                Kademe Ekle
            </MudButton>
        </MudStack>

        @if (_tiers is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudTable Items="_tiers" Dense="true" Hover="true" Elevation="0" Outlined="true">
                <HeaderContent>
                    <MudTh>Min Daire</MudTh>
                    <MudTh>Max Daire</MudTh>
                    <MudTh Style="text-align:right">Aylık Ücret (₺)</MudTh>
                    <MudTh Style="text-align:center">Sıra</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><strong>@context.MinDaire</strong></MudTd>
                    <MudTd>@(context.MaxDaire?.ToString() ?? "∞ (Sınırsız)")</MudTd>
                    <MudTd Style="text-align:right"><strong>@context.MonthlyAmount.ToString("N0") ₺</strong></MudTd>
                    <MudTd Style="text-align:center">@context.DisplayOrder</MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary" OnClick="@(() => OpenEditTier(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteTierAsync(context.Id))" />
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Fiyat, sitenin toplam daire sayısına göre ilk eşleşen kademe uygulanır.
            </MudText>
        }

        <!-- Tier Düzenleme Formu (inline) -->
        @if (_editingTier)
        {
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">@(_editTierId.HasValue ? "Kademe Düzenle" : "Yeni Kademe")</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6" sm="3">
                    <MudNumericField @bind-Value="_tierMin" Label="Min Daire" Variant="Variant.Outlined" Min="1" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudNumericField @bind-Value="_tierMax" Label="Max Daire (0=sınırsız)"
                                     Variant="Variant.Outlined" Min="0" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudNumericField @bind-Value="_tierAmount" Label="Aylık (₺)" Variant="Variant.Outlined"
                                     Min="0" Format="N0" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudNumericField @bind-Value="_tierOrder" Label="Sıra" Variant="Variant.Outlined" Min="1" />
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="SaveTierAsync" Disabled="_busyTier">Kaydet</MudButton>
                        <MudButton OnClick="@(() => _editingTier = false)">İptal</MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>

    <!-- Site Yükümlülükleri -->
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600">Site Yükümlülükleri</MudText>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@(_obligations?.Count ?? 0) Site</MudChip>
                <MudTooltip Text="Kademe değişikliği sonrası tüm sitelerin aylık ücretini yeniden hesaplar">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RecalculateAsync" Disabled="_recalculating">
                        @if (_recalculating) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                        Fiyatları Yenile
                    </MudButton>
                </MudTooltip>
            </MudStack>
        </MudStack>

        @if (_obligations is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_obligations.Count == 0)
        {
            <MudAlert Severity="Severity.Info">Henüz site yükümlülüğü yok.</MudAlert>
        }
        else
        {
            <MudTable Items="_obligations" Dense="true" Hover="true" Striped="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Firma</MudTh>
                    <MudTh>Site</MudTh>
                    <MudTh>Tip</MudTh>
                    <MudTh Style="text-align:right">Daire</MudTh>
                    <MudTh Style="text-align:right">Aylık (₺)</MudTh>
                    <MudTh Style="text-align:right">Bekleyen</MudTh>
                    <MudTh Style="text-align:right">Geciken</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.FirmName</MudTd>
                    <MudTd>@context.SiteName</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@SiteTypeColor(context.SiteType)">
                            @SiteTypeLabel(context.SiteType)
                        </MudChip>
                    </MudTd>
                    <MudTd Style="text-align:right">@context.DaireCount</MudTd>
                    <MudTd Style="text-align:right"><strong>@context.MonthlyAmount.ToString("N0") ₺</strong></MudTd>
                    <MudTd Style="text-align:right">
                        @if (context.PendingCount > 0)
                        { <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.PendingCount</MudChip> }
                        else { <MudText Color="Color.Success">✓</MudText> }
                    </MudTd>
                    <MudTd Style="text-align:right">
                        @if (context.OverdueCount > 0)
                        { <MudChip T="string" Size="Size.Small" Color="Color.Error">@context.OverdueCount</MudChip> }
                        else { <MudText Color="Color.Tertiary">—</MudText> }
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => OpenPaymentsDialog(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <!-- Bekleyen / Geciken Ödemeler -->
    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600">Bekleyen / Geciken Ödemeler</MudText>
            @if (_pendingPayments?.Count > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@_pendingPayments.Count</MudChip>
            }
        </MudStack>
        @if (_pendingPayments is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_pendingPayments.Count == 0)
        {
            <MudAlert Severity="Severity.Success">Bekleyen ödeme yok.</MudAlert>
        }
        else
        {
            <MudTable Items="_pendingPayments" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Site</MudTh>
                    <MudTh>Firma</MudTh>
                    <MudTh>Dönem</MudTh>
                    <MudTh Style="text-align:right">Borç (₺)</MudTh>
                    <MudTh Style="text-align:right">Ödenen (₺)</MudTh>
                    <MudTh>Vade</MudTh>
                    <MudTh>Durum</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.SiteName</MudTd>
                    <MudTd>@context.FirmSlug</MudTd>
                    <MudTd>@context.PeriodLabel</MudTd>
                    <MudTd Style="text-align:right">@context.AmountDue.ToString("N0")</MudTd>
                    <MudTd Style="text-align:right">@context.AmountPaid.ToString("N0")</MudTd>
                    <MudTd>
                        <MudText Color="@(context.DueDate < DateOnly.FromDateTime(DateTime.Today) ? Color.Error : Color.Default)">
                            @context.DueDate.ToString("dd.MM.yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">
                            @StatusLabel(context.Status)
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private List<SiteBillingTierDto>? _tiers;
    private List<SiteObligationDto>? _obligations;
    private List<ObligationPaymentDto>? _pendingPayments;

    private bool _editingTier;
    private bool _busyTier;
    private bool _recalculating;
    private int? _editTierId;
    private int _tierMin = 1, _tierMax = 0, _tierOrder = 1;
    private decimal _tierAmount;

    [Inject] IDialogService DialogService { get; set; } = default!;

    protected override async Task OnInitializedAsync() => await LoadAllAsync();

    private async Task LoadAllAsync()
    {
        _tiers = await ObligationService.GetTiersAsync();
        _obligations = await ObligationService.GetAllObligationsAsync();
        _pendingPayments = await ObligationService.GetAllPendingPaymentsAsync();
    }

    private void OpenAddTier()
    {
        _editTierId = null;
        _tierMin = 1; _tierMax = 0; _tierAmount = 0;
        _tierOrder = (_tiers?.Count ?? 0) + 1;
        _editingTier = true;
    }

    private void OpenEditTier(SiteBillingTierDto t)
    {
        _editTierId = t.Id;
        _tierMin = t.MinDaire; _tierMax = t.MaxDaire ?? 0;
        _tierAmount = t.MonthlyAmount; _tierOrder = t.DisplayOrder;
        _editingTier = true;
    }

    private async Task SaveTierAsync()
    {
        _busyTier = true;
        try
        {
            var cmd = new SiteBillingTierCommand(_tierMin, _tierMax == 0 ? null : _tierMax, _tierAmount, _tierOrder);
            await ObligationService.UpsertTierAsync(_editTierId, cmd);
            _editingTier = false;
            await LoadAllAsync();
            Snackbar.Add("Kademe kaydedildi.", Severity.Success);
        }
        finally { _busyTier = false; }
    }

    private async Task DeleteTierAsync(int id)
    {
        await ObligationService.DeleteTierAsync(id);
        await LoadAllAsync();
        Snackbar.Add("Silindi.", Severity.Info);
    }

    private async Task RecalculateAsync()
    {
        _recalculating = true;
        try
        {
            await ObligationService.RecalculateAllObligationsAsync();
            await LoadAllAsync();
            Snackbar.Add("Tüm site fiyatları güncellendi.", Severity.Success);
        }
        finally { _recalculating = false; }
    }

    private async Task OpenPaymentsDialog(SiteObligationDto ob)
    {
        var p = new DialogParameters<SiteObligationPaymentsDialog> { { x => x.Obligation, ob } };
        var dialog = await DialogService.ShowAsync<SiteObligationPaymentsDialog>(
            $"{ob.SiteName} — Ödemeler", p,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        await dialog.Result;
        await LoadAllAsync();
    }

    private static Color SiteTypeColor(SiteType t) => t switch
    {
        SiteType.Apartman => Color.Default, SiteType.TopluYapi => Color.Warning, _ => Color.Primary
    };
    private static string SiteTypeLabel(SiteType t) => t switch
    {
        SiteType.Apartman => "Apartman", SiteType.TopluYapi => "Toplu Yapı", _ => "Site"
    };
    private static Color StatusColor(ObligationPaymentStatus s) => s switch
    {
        ObligationPaymentStatus.Paid => Color.Success, ObligationPaymentStatus.Overdue => Color.Error,
        ObligationPaymentStatus.Partial => Color.Warning, _ => Color.Default
    };
    private static string StatusLabel(ObligationPaymentStatus s) => s switch
    {
        ObligationPaymentStatus.Paid => "Ödendi", ObligationPaymentStatus.Overdue => "Gecikmiş",
        ObligationPaymentStatus.Partial => "Kısmi", _ => "Bekliyor"
    };
}
