@inject IFirmRegistrationService FirmService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name" Label="Firma Adı" Required="true" Variant="Variant.Outlined" />
            @if (Firm is null)
            {
                <MudTextField @bind-Value="_slug" Label="Slug (URL)" Required="true" Variant="Variant.Outlined" HelperText="Küçük harf, tire ile — örn: abc-yonetim" />
            }
            else
            {
                <MudTextField Value="@Firm.Slug" Label="Slug (URL)" Variant="Variant.Outlined" ReadOnly="true" HelperText="Slug değiştirilemez." />
            }
            @if (_error is not null) { <MudAlert Severity="Severity.Error">@_error</MudAlert> }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="_busy">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Kaydet
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public FirmRegDto? Firm { get; set; }

    private string _name = "";
    private string _slug = "";
    private string? _error;
    private bool _busy;

    protected override void OnParametersSet()
    {
        if (Firm is not null) { _name = Firm.Name; _slug = Firm.Slug; }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_slug))
        { _error = "Ad ve slug zorunludur."; return; }
        _busy = true; _error = null;
        try
        {
            var slug = _slug.Trim().ToLower();
            if (Firm is null)
            {
                if (await FirmService.SlugExistsAsync(slug))
                { _error = "Bu slug zaten kullanımda."; return; }
                await FirmService.CreateAsync(new FirmRegCommand(_name.Trim(), slug));
            }
            else
            {
                await FirmService.UpdateAsync(Firm.Id, new FirmRegCommand(_name.Trim(), slug));
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
