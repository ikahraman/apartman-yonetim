@inject FirmDbContextFactory FirmFactory
@using ApartmanYonetim.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">@UserDisplayName için erişilebilir siteler:</MudText>
            @if (_allSites.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Warning">Bu kullanıcının bağlı olduğu firma bulunamadı veya site yok.</MudText>
            }
            @foreach (var site in _allSites)
            {
                var s = site;
                <MudCheckBox T="bool" Value="@_selected.Contains(s.SiteId)"
                             ValueChanged="@(v => Toggle(s.SiteId, v))"
                             Label="@s.Name" />
            }
            @if (_error is not null) { <MudAlert Severity="Severity.Error">@_error</MudAlert> }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_busy">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Kaydet
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string UserId { get; set; } = "";
    [Parameter] public string UserDisplayName { get; set; } = "";
    [Parameter] public string? FirmSlug { get; set; }

    private record SiteRow(Guid SiteId, string Name);
    private List<SiteRow> _allSites = [];
    private HashSet<Guid> _selected = [];
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (FirmSlug is null) return;
        await using var firmDb = FirmFactory.CreateBySlug(FirmSlug);
        var sites = await firmDb.Sites.OrderBy(s => s.Name).ToListAsync();
        _allSites = sites.Select(s => new SiteRow(s.Id, s.Name)).ToList();
        var current = await firmDb.UserSiteAccess.Where(a => a.UserId == UserId).Select(a => a.SiteId).ToListAsync();
        _selected = current.ToHashSet();
    }

    private void Toggle(Guid siteId, bool value)
    {
        if (value) _selected.Add(siteId);
        else _selected.Remove(siteId);
    }

    private async Task SaveAsync()
    {
        if (FirmSlug is null) { MudDialog.Cancel(); return; }
        _busy = true; _error = null;
        try
        {
            await using var firmDb = FirmFactory.CreateBySlug(FirmSlug);
            var existing = await firmDb.UserSiteAccess.Where(a => a.UserId == UserId).ToListAsync();
            firmDb.UserSiteAccess.RemoveRange(existing);
            foreach (var siteId in _selected)
                firmDb.UserSiteAccess.Add(new ApartmanYonetim.Domain.Entities.UserSiteAccess { UserId = UserId, SiteId = siteId });
            await firmDb.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
