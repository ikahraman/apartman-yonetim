@page "/admin/siteler"
@attribute [Authorize(Roles = "SuperAdmin")]
@inject IFirmRegistrationService FirmService
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Siteler</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5" Style="font-weight:700">Siteler / Apartmanlar</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">Site Ekle</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudTable T="AdminSiteDto" Items="_sites" Hover="true" Elevation="1" Dense="true">
            <HeaderContent>
                <MudTh>Site Adı</MudTh>
                <MudTh>Tip</MudTh>
                <MudTh>Firma</MudTh>
                <MudTh>Şehir</MudTh>
                <MudTh>Daire</MudTh>
                <MudTh>Sözleşme Bitiş</MudTh>
                <MudTh>Durum</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Style="font-weight:500">@context.Name</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@SiteTypeColor(context.SiteType)">
                        @SiteTypeLabel(context.SiteType)
                    </MudChip>
                </MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Info">@context.FirmName</MudChip></MudTd>
                <MudTd>@(context.City ?? "—")</MudTd>
                <MudTd>@(context.UnitCount > 0 ? context.UnitCount.ToString() : "—")</MudTd>
                <MudTd>
                    @if (context.ContractEndDate.HasValue)
                    {
                        var isExpired = context.ContractEndDate.Value < DateOnly.FromDateTime(DateTime.Today);
                        var isExpiringSoon = !isExpired && context.ContractEndDate.Value < DateOnly.FromDateTime(DateTime.Today.AddDays(60));
                        <MudText Typo="Typo.body2" Color="@(isExpired ? Color.Error : isExpiringSoon ? Color.Warning : Color.Default)">
                            @context.ContractEndDate.Value.ToString("dd.MM.yyyy")
                        </MudText>
                    }
                    else { <MudText Typo="Typo.body2" Color="Color.Default">—</MudText> }
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                        @(context.IsActive ? "Aktif" : "Pasif")
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="0">
                        @if (context.SiteType != SiteType.Apartman)
                        {
                            <MudTooltip Text="Yapı yönetimi (blok/kısım)">
                                <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary"
                                               OnClick="() => OpenStructureDialog(context)" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Sakinler">
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Secondary"
                                           OnClick="@(() => GoToSite(context.Id))" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    private List<AdminSiteDto> _sites = [];
    private bool _loading = true;
    private Guid? _navigatingId;

    private void GoToSite(Guid id) { _navigatingId = id; Nav.NavigateTo($"/site/{id}/sakinler"); }

    protected override async Task OnInitializedAsync()
    {
        _sites = await FirmService.GetAllSitesAsync();
        _loading = false;
    }

    private async Task OpenAddDialog()
    {
        var firms = await FirmService.GetAllAsync();
        var p = new DialogParameters<AdminSiteFormDialog> { { x => x.Firms, firms } };
        var dialog = await DialogService.ShowAsync<AdminSiteFormDialog>("Site Ekle", p, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: AdminSiteDto created })
        {
            _loading = true;
            _sites = await FirmService.GetAllSitesAsync();
            _loading = false;

            if (created.SiteType != SiteType.Apartman)
                await OpenStructureDialog(created);
        }
    }

    private async Task OpenStructureDialog(AdminSiteDto site)
    {
        var p = new DialogParameters<SiteBlocksDialog>
        {
            { x => x.DbFilePath, site.DbFilePath },
            { x => x.SiteType, site.SiteType }
        };
        await DialogService.ShowAsync<SiteBlocksDialog>(
            $"{site.Name} — Yapı Yönetimi", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private static Color SiteTypeColor(SiteType t) => t switch
    {
        SiteType.Apartman => Color.Default,
        SiteType.TopluYapi => Color.Warning,
        _ => Color.Primary
    };

    private static string SiteTypeLabel(SiteType t) => t switch
    {
        SiteType.Apartman => "Apartman",
        SiteType.TopluYapi => "Toplu Yapı",
        _ => "Site"
    };
}
