@page "/bilgi/sablonlar"
@layout PublicLayout
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Hazır Şablonlar — ApartNet</PageTitle>

<div style="background:linear-gradient(90deg,#E65100,#EF6C00);color:white;padding:20px 16px">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size:2rem" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5" Style="font-weight:800">Hazır Şablonlar</MudText>
                <MudText Typo="Typo.body2" Style="opacity:0.85">Kopyalayın, doldurun, kullanın — ücretsiz</MudText>
            </MudStack>
        </MudStack>
    </MudContainer>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-5">

    @* Kategori Filtresi *@
    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-4">
        <MudChip T="string" Color="@(_secili == null ? Color.Primary : Color.Default)"
                  OnClick="@(() => _secili = null)" Style="cursor:pointer">Tümü</MudChip>
        @foreach (var kat in _kategoriler)
        {
            <MudChip T="string" Color="@(_secili == kat ? Color.Primary : Color.Default)"
                      OnClick="@(() => _secili = kat)" Style="cursor:pointer">@kat</MudChip>
        }
    </MudStack>

    <MudGrid Spacing="3">
        @foreach (var sablon in FilteredSablonlar)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="height:100%">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="@sablon.Renk">
                                <MudIcon Icon="@sablon.Icon" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700">@sablon.Baslik</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="height:20px">@sablon.Kategori</MudChip>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@sablon.Aciklama</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   OnClick="@(() => KopyalaAsync(sablon))">
                            Kopyala
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                   OnClick="@(() => _gorunutlenen = _gorunutlenen == sablon ? null : sablon)">
                            @(_gorunutlenen == sablon ? "Gizle" : "Önizle")
                        </MudButton>
                    </MudCardActions>
                    @if (_gorunutlened == sablon)
                    {
                        <MudCardContent>
                            <MudPaper Outlined="true" Class="pa-3" Style="background:#FAFAFA;max-height:300px;overflow-y:auto">
                                <pre style="white-space:pre-wrap;font-size:12px;font-family:monospace">@sablon.Icerik</pre>
                            </MudPaper>
                        </MudCardContent>
                    }
                </MudCard>
            </MudItem>
        }
    </MudGrid>

</MudContainer>

@code {
    private string? _secili;
    private Sablon? _gorunutlened;
    private Sablon? _gorunutlenen
    {
        get => _gorunutlened;
        set { _gorunutlened = value; StateHasChanged(); }
    }

    private string[] _kategoriler = ["Toplantı", "Aidat", "Bildirim", "Sözleşme", "Dilekçe"];

    private IEnumerable<Sablon> FilteredSablonlar =>
        _secili is null ? _sablonlar : _sablonlar.Where(s => s.Kategori == _secili);

    private async Task KopyalaAsync(Sablon s)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", s.Icerik);
        Snackbar.Add($"'{s.Baslik}' kopyalandı!", Severity.Success);
    }

