@page "/bilgi/servis-rehberi"
@layout PublicLayout

<PageTitle>Servis Rehberi — ApartNet</PageTitle>

<div style="background:linear-gradient(90deg,#1B5E20,#2E7D32);color:white;padding:20px 16px">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Handyman" Style="font-size:2rem" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5" Style="font-weight:800">Servis & Firma Rehberi</MudText>
                <MudText Typo="Typo.body2" Style="opacity:0.85">Apartman ve site yönetimi için güvenilir hizmet firmaları</MudText>
            </MudStack>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                       StartIcon="@Icons.Material.Filled.AddBusiness"
                       Style="border-color:rgba(255,255,255,0.6)">
                Firmanızı Ekleyin
            </MudButton>
        </MudStack>
    </MudContainer>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-5">

    @* Kategori Kartları *@
    <MudText Typo="Typo.h6" Style="font-weight:700" Class="mb-3">Hizmet Kategorileri</MudText>
    <MudGrid Spacing="3" Class="mb-6">
        @foreach (var kat in _kategoriler)
        {
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="@(_secili == kat.Ad ? 4 : 1)" Class="pa-3 text-center"
                          Style="@($"cursor:pointer;border:2px solid {(_secili == kat.Ad ? "var(--mud-palette-primary)" : "transparent")}")"
                          @onclick="@(() => _secili = _secili == kat.Ad ? null : kat.Ad)">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@kat.Icon" Color="@(_secili == kat.Ad ? Color.Primary : Color.Default)" Style="font-size:2rem" />
                        <MudText Typo="Typo.caption" Style="font-weight:600;text-align:center">@kat.Ad</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    @* Firma Listesi *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6" Style="font-weight:700">
            @(_secili ?? "Tüm Firmalar")
        </MudText>
        @if (_secili is not null)
        {
            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _secili = null)">Tümünü Göster</MudButton>
        }
        <MudSpacer />
        <MudText Typo="Typo.caption" Color="Color.Secondary">@FilteredFirmalar.Count() firma listelendi</MudText>
    </MudStack>

    <MudGrid Spacing="3">
        @foreach (var firma in FilteredFirmalar)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="height:100%">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary" Style="font-weight:700">@firma.Ad[0]</MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700">@firma.Ad</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="height:20px">@firma.Kategori</MudChip>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudTooltip Text="Doğrulanmış firma">
                                <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Primary" Size="Size.Small"
                                         Style="@(firma.Onaylı ? "" : "visibility:hidden")" />
                            </MudTooltip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@firma.Sehir</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2">@firma.Aciklama</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                @for (int i = 0; i < 5; i++)
                                {
                                    var idx = i;
                                    <MudIcon Icon="@(idx < firma.Puan ? Icons.Material.Filled.Star : Icons.Material.Outlined.Star)"
                                             Style="font-size:16px;color:#FFC107" />
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">(@firma.YorumSayisi yorum)</MudText>
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Phone">İletişim</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small">Detay</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    @* Firma Ekle CTA *@
    <MudPaper Elevation="1" Class="pa-5 mt-6" Style="background:#F5F5F5;text-align:center">
        <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Color="Color.Primary" Style="font-size:3rem" Class="mb-2" />
        <MudText Typo="Typo.h6" Style="font-weight:700" Class="mb-1">Firmanızı Ekleyin</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Apartman ve site yöneticilerine ulaşmak için firmanızı ücretsiz listeleyin.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.AddBusiness" Style="border-radius:24px">
            Ücretsiz Firma Kaydı
        </MudButton>
    </MudPaper>

</MudContainer>

@code {
