@page "/sitelerim-dashboard"
@attribute [Authorize]
@inject ISiteManagementService SiteService
@inject IManagementCompanyService CompanyService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Ana Sayfa — Apartman Yönetim</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1" Style="font-weight:700">Hoşgeldiniz</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @_displayName · @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
</MudText>

@if (_sites is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_sites.Count == 0)
{
    <MudAlert Severity="Severity.Info">Henüz yönetilen site bulunmuyor.</MudAlert>
}
else
{
    @foreach (var group in _sites.GroupBy(s => s.CompanyName).OrderBy(g => g.Key))
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3 mt-2">
            <MudAvatar Color="Color.Primary" Size="Size.Small">
                <MudIcon Icon="@Icons.Material.Filled.Business" />
            </MudAvatar>
            <MudText Typo="Typo.h6" Style="font-weight:700">@group.Key</MudText>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@group.Count() Site</MudChip>
        </MudStack>

        <MudGrid Spacing="3" Class="mb-5">
            @foreach (var site in group)
            {
                var s = site;
                var daysLeft = s.ContractEndDate.HasValue
                    ? (s.ContractEndDate.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days
                    : (int?)null;

                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2" Style="cursor:pointer" @onclick="@(() => GoToSite(s.Id))">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="@(daysLeft is <= 30 ? Color.Error : daysLeft is <= 90 ? Color.Warning : Color.Primary)">
                                    <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="font-weight:600">@s.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@s.City</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap">
                                    <MudChip T="string" Size="Size.Small" Color="@SiteTypeColor(s.SiteType)">@SiteTypeLabel(s.SiteType)</MudChip>
                                    @if (s.UnitCount > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Home">@s.UnitCount Birim</MudChip>
                                    }
                                </MudStack>
                                @if (daysLeft.HasValue && daysLeft <= 90)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small"
                                                 Color="@(daysLeft <= 30 ? Color.Error : Color.Warning)" />
                                        <MudText Typo="Typo.caption"
                                                 Style="@(daysLeft <= 30 ? "color:var(--mud-palette-error)" : "color:var(--mud-palette-warning)")">
                                            @(daysLeft <= 0 ? "Sözleşme süresi doldu!" : $"Sözleşme {daysLeft} gün sonra bitiyor")
                                        </MudText>
                                    </MudStack>
                                }
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ManageAccounts"
                                       Disabled="@(_loadingSiteId == s.Id)"
                                       OnClick="@(() => GoToSite(s.Id))">
                                @if (_loadingSiteId == s.Id)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                    <span>Yükleniyor...</span>
                                }
                                else
                                {
                                    <span>Yönet</span>
                                }
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private List<SiteDto>? _sites;
    private string _displayName = "";
    private Guid? _loadingSiteId;

    private void GoToSite(Guid id)
    {
        _loadingSiteId = id;
        Nav.NavigateTo($"/site/{id}/ozet");
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _displayName = user.FindFirst("DisplayName")?.Value ?? user.Identity?.Name ?? "";
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (user.IsInRole("SuperAdmin"))
        {
            Nav.NavigateTo("/admin/firmalar");
            return;
        }


        _sites = await SiteService.GetForUserAsync(userId);
    }

    private static Color SiteTypeColor(SiteType t) => t switch
    {
        SiteType.Apartman  => Color.Default,
        SiteType.TopluYapi => Color.Warning,
        _                  => Color.Primary
    };

    private static string SiteTypeLabel(SiteType t) => t switch
    {
        SiteType.Apartman  => "Apartman",
        SiteType.TopluYapi => "Toplu Yapı",
        _                  => "Site"
    };
}
