@page "/"
@attribute [Authorize]
@inject ISiteManagementService SiteService
@inject IManagementCompanyService CompanyService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Ana Sayfa — Apartman Yönetim</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1" Style="font-weight:700">Hoşgeldiniz</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @_displayName · @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
</MudText>

@if (_sites is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_sites.Count == 0)
{
    <MudAlert Severity="Severity.Info">Henüz yönetilen site bulunmuyor.</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var site in _sites)
        {
            var s = site;
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="cursor:pointer" @onclick="@(() => GoToSite(s.Id))">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary">
                                <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Style="font-weight:600">@s.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@s.CompanyName</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="1">
                            @if (s.City is not null)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">@s.City</MudText>
                                </MudStack>
                            }
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@s.UnitCount Daire</MudText>
                            </MudStack>
                            @if (s.Address is not null)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@s.Address</MudText>
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ManageAccounts"
                                   OnClick="@(() => GoToSite(s.Id))">
                            Yönet
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<SiteDto>? _sites;
    private string _displayName = "";

    private void GoToSite(Guid id) => Nav.NavigateTo($"/site/{id}/ozet");

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _displayName = user.FindFirst("DisplayName")?.Value ?? user.Identity?.Name ?? "";
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (user.IsInRole("Resident"))
        {
            Nav.NavigateTo("/sakin");
            return;
        }

        if (user.IsInRole("SuperAdmin"))
        {
            Nav.NavigateTo("/admin/firmalar");
            return;
        }

        _sites = await SiteService.GetForUserAsync(userId);
    }
}
