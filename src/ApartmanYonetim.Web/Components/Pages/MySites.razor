@page "/sitelerim"
@attribute [Authorize(Roles = "SuperAdmin,Manager,SiteStaff,Auditor,Accountant")]
@inject ISiteManagementService SiteService
@inject ISiteResidentService ResidentService
@inject IFirmSubscriptionService SubService
@inject ISiteObligationService ObligationService
@inject IManagementCompanyService CompanyService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Sitelerim</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">

    @if (_isManager && _companyName is not null)
    {
        <MudPaper Elevation="0" Class="mb-4 pa-4"
                  Style="background:linear-gradient(135deg,var(--mud-palette-primary) 0%,var(--mud-palette-primary-darken) 100%);border-radius:12px;color:#fff">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h6" Style="font-weight:700;color:#fff">Hoş geldiniz, @_displayName</MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85)">
                        @_companyName — Yönetici
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.7);margin-top:4px">
                        Yönetmek istediğiniz siteyi seçip <strong>Yönet</strong> butonuna tıklayın.
                        @if (_sites is not null)
                        {
                            <text> · @_sites.Count site · @_sites.Sum(s => s.UnitCount) birim</text>
                        }
                    </MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.AddHome"
                           OnClick="OpenAddSiteDialog"
                           Style="font-weight:600">
                    Yeni Site Ekle
                </MudButton>
            </MudStack>
        </MudPaper>
    }

    @if (_sub is not null)
    {
        @if (_sub.Status == SubscriptionStatus.Suspended || _sub.Status == SubscriptionStatus.Cancelled)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Icon="@Icons.Material.Filled.Block">
                <strong>Aboneliğiniz askıya alındı.</strong> Sisteme erişiminiz kısıtlanmıştır.
                Ödeme ve abonelik durumu için yöneticinizle iletişime geçin.
            </MudAlert>
        }
        else if (_sub.Status == SubscriptionStatus.Overdue)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Icon="@Icons.Material.Filled.Warning">
                <strong>Abonelik ödemesi gecikmiş.</strong> Ödemeniz yapılmazsa sistem erişiminiz kesilebilir.
                Lütfen yöneticinizle iletişime geçin.
            </MudAlert>
        }
    }

    @if (_overdueObligations > 0)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.AccountBalanceWallet">
            <strong>@_overdueObligations gecikmiş site ödemesi</strong> var.
            <MudLink Href="/firma/faturalama" Color="Color.Warning" Style="font-weight:600">Faturalama sayfasına git →</MudLink>
        </MudAlert>
    }

    @if (_sites is null)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_sites.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Henüz size atanmış site bulunmuyor.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var site in _sites)
            {
                var s = site;
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="@SiteTypeColor(s.SiteType)">
                                    <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="font-weight:600">@s.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@s.CompanyName</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap">
                                    <MudChip T="string" Size="Size.Small" Color="@SiteTypeColor(s.SiteType)">
                                        @SiteTypeLabel(s.SiteType)
                                    </MudChip>
                                    @if (s.City is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.LocationOn">@s.City</MudChip>
                                    }
                                    @if (s.UnitCount > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Home">@s.UnitCount Birim</MudChip>
                                    }
                                </MudStack>
                                @if (s.ContractEndDate.HasValue)
                                {
                                    var expired = s.ContractEndDate.Value < DateOnly.FromDateTime(DateTime.Today);
                                    var soon = !expired && s.ContractEndDate.Value < DateOnly.FromDateTime(DateTime.Today.AddDays(60));
                                    <MudText Typo="Typo.caption" Color="@(expired ? Color.Error : soon ? Color.Warning : Color.Secondary)">
                                        Sözleşme: @s.ContractEndDate.Value.ToString("dd.MM.yyyy")
                                        @(expired ? " (Süresi doldu)" : soon ? " (Yakında bitiyor)" : "")
                                    </MudText>
                                }
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ManageAccounts"
                                       Disabled="@(_loadingSiteId == s.Id)"
                                       OnClick="@(() => GoToSite(s.Id))">
                                @if (_loadingSiteId == s.Id)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                    <span>Yükleniyor...</span>
                                }
                                else
                                {
                                    <span>Yönet</span>
                                }
                            </MudButton>
                            @if (_isManager && s.SiteType != SiteType.Apartman)
                            {
                                <MudTooltip Text="Blok / Kısım yapısını düzenle">
                                    <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                                                   Color="Color.Secondary" OnClick="@(() => OpenStructureDialog(s))" />
                                </MudTooltip>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "ekle")] private string? EkleParam { get; set; }

    private List<SiteDto>? _sites;
    private bool _isManager;
    private Guid? _loadingSiteId;
    private SubscriptionDto? _sub;
    private int _overdueObligations;
    private string? _companyName;
    private string? _displayName;

    private void GoToSite(Guid id)
    {
        _loadingSiteId = id;
        Nav.NavigateTo($"/site/{id}/ozet");
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _isManager = user.IsInRole("Manager") || user.IsInRole("SuperAdmin");
        _displayName = user.FindFirst("DisplayName")?.Value ?? user.Identity?.Name ?? "";
        _sites = await SiteService.GetForUserAsync(userId);

        var firmSlug = user.FindFirst("firm_slug")?.Value;
        if (_isManager && firmSlug is not null)
        {
            _sub = await SubService.GetSubscriptionByFirmAsync(firmSlug);
            var obs = await ObligationService.GetObligationsByFirmAsync(firmSlug);
            _overdueObligations = obs.Sum(o => o.OverdueCount);
            var companies = await CompanyService.GetForUserAsync(userId);
            _companyName = companies.FirstOrDefault()?.Name;
        }

        if (EkleParam == "1" && _isManager)
            await OpenAddSiteDialog();
    }

    private async Task OpenAddSiteDialog()
    {
        var dialog = await DialogService.ShowAsync<ManagerSiteFormDialog>("Yeni Site Ekle",
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if (!(await dialog.Result)!.Canceled)
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
            _sites = await SiteService.GetForUserAsync(userId);
        }
    }

    private async Task OpenStructureDialog(SiteDto site)
    {
        var p = new DialogParameters<SiteBlocksDialog>
        {
            { x => x.DbFilePath, site.DbFilePath },
            { x => x.SiteType, site.SiteType }
        };
        await DialogService.ShowAsync<SiteBlocksDialog>(
            $"{site.Name} — Yapı Yönetimi", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private static Color SiteTypeColor(SiteType t) => t switch
    {
        SiteType.Apartman  => Color.Default,
        SiteType.TopluYapi => Color.Warning,
        _                  => Color.Primary
    };

    private static string SiteTypeLabel(SiteType t) => t switch
    {
        SiteType.Apartman  => "Apartman",
        SiteType.TopluYapi => "Toplu Yapı",
        _                  => "Site"
    };
}
