@page "/sitelerim"
@attribute [Authorize(Roles = "Manager,SiteStaff,Auditor")]
@inject ISiteManagementService SiteService
@inject ISiteResidentService ResidentService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Sitelerim</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudText Typo="Typo.h5" Style="font-weight:700" Class="mb-4">Yönettiğim Siteler</MudText>

    @if (_sites is null)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_sites.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Henüz size atanmış site bulunmuyor.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var site in _sites)
            {
                var s = site;
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="@SiteTypeColor(s.SiteType)">
                                    <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="font-weight:600">@s.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@s.CompanyName</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudStack Row="true" Spacing="1" Style="flex-wrap:wrap">
                                    <MudChip T="string" Size="Size.Small" Color="@SiteTypeColor(s.SiteType)">
                                        @SiteTypeLabel(s.SiteType)
                                    </MudChip>
                                    @if (s.City is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.LocationOn">@s.City</MudChip>
                                    }
                                    @if (s.UnitCount > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Home">@s.UnitCount Birim</MudChip>
                                    }
                                </MudStack>
                                @if (s.ContractEndDate.HasValue)
                                {
                                    var expired = s.ContractEndDate.Value < DateOnly.FromDateTime(DateTime.Today);
                                    var soon = !expired && s.ContractEndDate.Value < DateOnly.FromDateTime(DateTime.Today.AddDays(60));
                                    <MudText Typo="Typo.caption" Color="@(expired ? Color.Error : soon ? Color.Warning : Color.Secondary)">
                                        Sözleşme: @s.ContractEndDate.Value.ToString("dd.MM.yyyy")
                                        @(expired ? " (Süresi doldu)" : soon ? " (Yakında bitiyor)" : "")
                                    </MudText>
                                }
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ManageAccounts"
                                       OnClick="@(() => GoToSite(s.Id))">
                                Yönet
                            </MudButton>
                            @if (_isManager && s.SiteType != SiteType.Apartman)
                            {
                                <MudTooltip Text="Blok / Kısım yapısını düzenle">
                                    <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                                                   Color="Color.Secondary" OnClick="@(() => OpenStructureDialog(s))" />
                                </MudTooltip>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<SiteDto>? _sites;
    private bool _isManager;

    private void GoToSite(Guid id) => Nav.NavigateTo($"/site/{id}/ozet");

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _isManager = user.IsInRole("Manager") || user.IsInRole("SuperAdmin");
        _sites = await SiteService.GetForUserAsync(userId);
    }

    private async Task OpenStructureDialog(SiteDto site)
    {
        var p = new DialogParameters<SiteBlocksDialog>
        {
            { x => x.DbFilePath, site.DbFilePath },
            { x => x.SiteType, site.SiteType }
        };
        await DialogService.ShowAsync<SiteBlocksDialog>(
            $"{site.Name} — Yapı Yönetimi", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private static Color SiteTypeColor(SiteType t) => t switch
    {
        SiteType.Apartman  => Color.Default,
        SiteType.TopluYapi => Color.Warning,
        _                  => Color.Primary
    };

    private static string SiteTypeLabel(SiteType t) => t switch
    {
        SiteType.Apartman  => "Apartman",
        SiteType.TopluYapi => "Toplu Yapı",
        _                  => "Site"
    };
}
