@page "/giris"
@layout ApartmanYonetim.Web.Components.Layout.MainLayout
@inject IJSRuntime JS

<PageTitle>Giriş — Apartman Yönetim</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:80vh">
    <MudPaper Elevation="4" Class="pa-8" Style="width:100%;max-width:420px">
        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Apartment" Color="Color.Primary" Style="font-size:3rem" />
            <MudText Typo="Typo.h5" Style="font-weight:700">Apartman Yönetim</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Hesabınızla giriş yapın</MudText>
        </MudStack>

        <form method="post" action="/api/auth/login">
            <input type="hidden" name="returnUrl" value="@_returnUrl" />
            <MudTextField T="string" name="email" Label="E-posta" InputType="InputType.Email"
                          Variant="Variant.Outlined" Class="mb-3" autocomplete="email" />
            <MudTextField T="string" name="password" Label="Şifre" InputType="InputType.Password"
                          Variant="Variant.Outlined" Class="mb-4" autocomplete="current-password" />
            @if (_error)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">
                    E-posta veya şifre hatalı.
                </MudAlert>
            }
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                       Color="Color.Primary" FullWidth="true" Size="Size.Large">
                Giriş Yap
            </MudButton>
        </form>

        <MudButton Href="/" Variant="Variant.Text" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack" FullWidth="true" Class="mt-3">
            Ana Sayfaya Dön
        </MudButton>

        <MudDivider Class="my-4" />
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Style="font-family:monospace;font-weight:700;height:20px">DEV</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Test kullanıcıları — tıkla, doldur:</MudText>
            </MudStack>
            @foreach (var u in _devUsers)
            {
                var cu = u;
                <MudPaper Outlined="true" Class="pa-2" Style="cursor:pointer;user-select:none" @onclick="@(() => FillLoginAsync(cu.Email, cu.Password))">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudChip T="string" Size="Size.Small" Color="@cu.RoleColor" Style="height:20px;margin:0">@cu.Role</MudChip>
                        <MudText Typo="Typo.caption" Style="flex:1">@cu.Email</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family:monospace">@cu.Password</MudText>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Hata { get; set; }
    private string _returnUrl = "/";
    private bool _error;

    private record DevUser(string Role, string Email, string Password, Color RoleColor);
    private static readonly DevUser[] _devUsers = [
        new("SuperAdmin", "admin@ay.com",     "Admin1234!",    Color.Error),
        new("Manager",    "ozgur@ay.com",     "Ozgur1234!",    Color.Primary),
        new("Manager",    "sevgi@ay.com",     "Sevgi1234!",    Color.Primary),
        new("SiteStaff",  "personel@ay.com",  "Personel1234!", Color.Info),
        new("Auditor",    "denetci@ay.com",   "Denetci1234!",  Color.Warning),
        new("Resident",   "sakin@ay.com",     "Sakin1234!",    Color.Success),
    ];

    protected override void OnInitialized()
    {
        _returnUrl = ReturnUrl ?? "/";
        _error = Hata == "1";
    }

    private async Task FillLoginAsync(string email, string password)
    {
        await JS.InvokeVoidAsync("eval",
            $"document.querySelector('input[name=\"email\"]').value='{email}';" +
            $"document.querySelector('input[name=\"password\"]').value='{password}';");
    }
}
