<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle">
                <strong>@ResidentName</strong> için portal hesabı oluşturuldu.
            </MudAlert>
            <MudAlert Severity="Severity.Warning">
                Bu bilgileri sakinle paylaşın. Şifre bir daha gösterilmeyecek.
            </MudAlert>
            <MudTextField Value="@ResidentName" Label="Sakin" ReadOnly="true" Variant="Variant.Outlined" />
            <MudTextField @ref="_userNameField" Value="@UserName" Label="Kullanıcı Adı" ReadOnly="true"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="CopyUserName" />
            <MudTextField @ref="_passwordField" Value="@Password" Label="Şifre" ReadOnly="true"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="CopyPassword" />
            @if (_copied)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Panoya kopyalandı.</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => MudDialog.Close())">Tamam</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string ResidentName { get; set; } = "";
    [Parameter] public string UserName { get; set; } = "";
    [Parameter] public string Password { get; set; } = "";

    [Inject] IJSRuntime JS { get; set; } = default!;

    private MudTextField<string>? _userNameField;
    private MudTextField<string>? _passwordField;
    private bool _copied;

    private async Task CopyUserName() => await CopyToClipboard(UserName);
    private async Task CopyPassword() => await CopyToClipboard(Password);

    private async Task CopyToClipboard(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { }
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
    }
}
