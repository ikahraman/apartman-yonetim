@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<MudPaper Elevation="1" Class="mb-4 px-2 py-1">
    <MudStack Spacing="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex-wrap:wrap" Class="pt-1 px-1">
            <MudIcon Icon="@Icons.Material.Filled.Apartment" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:700;white-space:nowrap">@SiteName</MudText>
            <MudChip T="string" Size="Size.Small" Color="@SiteTypeColor(SiteType)">@SiteTypeLabel(SiteType)</MudChip>
            @if (City is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.LocationOn">@City</MudChip>
            }
            @if (UnitCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Home">@UnitCount Birim</MudChip>
            }
        </MudStack>
        <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;white-space:nowrap;padding-bottom:2px">
            @foreach (var (label, icon, route, staffVisible) in _modules)
            {
                @if (!staffVisible && _isSiteStaff) { continue; }
                var r = route;
                var active = route == ActiveRoute;
                <MudButton StartIcon="@icon" Size="Size.Small"
                           Variant="@(active ? Variant.Filled : Variant.Text)"
                           Color="@(active ? Color.Primary : Color.Default)"
                           OnClick="@(() => Navigate(r))"
                           Style="white-space:nowrap;min-width:auto"
                           Class="mr-1">
                    @label
                </MudButton>
            }
        </div>
    </MudStack>
</MudPaper>

@code {
    [Parameter] public Guid SiteId { get; set; }
    [Parameter] public string SiteName { get; set; } = "";
    [Parameter] public string? City { get; set; }
    [Parameter] public int UnitCount { get; set; }
    [Parameter] public string ActiveRoute { get; set; } = "";
    [Parameter] public SiteType SiteType { get; set; } = SiteType.Site;

    private bool _isSiteStaff;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _isSiteStaff = auth.User.IsInRole("SiteStaff") &&
                       !auth.User.IsInRole("Manager") &&
                       !auth.User.IsInRole("SuperAdmin");
    }

    private void Navigate(string route) => Nav.NavigateTo($"/site/{SiteId}/{route}");

    private static Color SiteTypeColor(SiteType t) => t switch
    {
        SiteType.Apartman  => Color.Default,
        SiteType.TopluYapi => Color.Warning,
        _                  => Color.Primary
    };

    private static string SiteTypeLabel(SiteType t) => t switch
    {
        SiteType.Apartman  => "Apartman",
        SiteType.TopluYapi => "Toplu Yapı",
        _                  => "Site"
    };

    // staffVisible: false = SiteStaff'a gizli
    private static readonly (string Label, string Icon, string Route, bool StaffVisible)[] _modules =
    [
        ("Özet",      Icons.Material.Filled.Dashboard,     "ozet",     true),
        ("Sakinler",  Icons.Material.Filled.People,         "sakinler", true),
        ("Aidatlar",  Icons.Material.Filled.AccountBalance, "aidatlar", false),
        ("Duyurular", Icons.Material.Filled.Notifications,  "duyurular",true),
        ("Arızalar",  Icons.Material.Filled.Build,          "arizalar", true),
        ("Toplantılar",Icons.Material.Filled.Groups,        "toplanti", true),
        ("Muhasebe",  Icons.Material.Filled.ReceiptLong,    "muhasebe", false),
    ];
}
