@inject ISiteResidentService ResidentService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_firstName" Label="Ad" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_lastName" Label="Soyad" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_phone" Label="Telefon" Variant="Variant.Outlined" InputType="InputType.Telephone" />
            <MudTextField @bind-Value="_email" Label="E-posta" Variant="Variant.Outlined" InputType="InputType.Email" />
            <MudSelect @bind-Value="_residencyType" Label="Oturma Türü" Variant="Variant.Outlined" Required="true">
                <MudSelectItem Value="ResidencyType.Owner">Mal Sahibi</MudSelectItem>
                <MudSelectItem Value="ResidencyType.Tenant">Kiracı</MudSelectItem>
                <MudSelectItem Value="ResidencyType.Family">Aile Üyesi</MudSelectItem>
            </MudSelect>
            <MudDatePicker @bind-Date="_moveInDate" Label="Giriş Tarihi" Variant="Variant.Outlined" DateFormat="dd.MM.yyyy" />
            <MudTextField @bind-Value="_notes" Label="Notlar" Variant="Variant.Outlined" Lines="2" />
            @if (_error is not null) { <MudAlert Severity="Severity.Error">@_error</MudAlert> }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="_busy">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Kaydet
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string DbFilePath { get; set; } = "";
    [Parameter] public UnitSummaryDto Unit { get; set; } = default!;

    private string _firstName = "";
    private string _lastName = "";
    private string? _phone;
    private string? _email;
    private ResidencyType _residencyType = ResidencyType.Tenant;
    private DateTime? _moveInDate = DateTime.Today;
    private string? _notes;
    private string? _error;
    private bool _busy;

    protected override void OnParametersSet()
    {
        if (Unit.ResidentId is not null)
        {
            _firstName = Unit.ResidentName?.Split(' ').FirstOrDefault() ?? "";
            _lastName = string.Join(' ', Unit.ResidentName?.Split(' ').Skip(1) ?? []);
            _phone = Unit.ResidentPhone;
            _email = Unit.ResidentEmail;
            _residencyType = Unit.ResidencyType ?? ResidencyType.Tenant;
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
        { _error = "Ad ve soyad zorunludur."; return; }
        _busy = true; _error = null;
        try
        {
            var moveIn = DateOnly.FromDateTime(_moveInDate ?? DateTime.Today);
            var cmd = new ResidentFormCommand(_firstName.Trim(), _lastName.Trim(), _phone, _email, _residencyType, moveIn, _notes);

            if (Unit.ResidentId is null)
            {
                await ResidentService.AddResidentAsync(DbFilePath, Unit.Id, cmd);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                await ResidentService.UpdateResidentAsync(DbFilePath, Unit.ResidentId.Value, cmd);
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
