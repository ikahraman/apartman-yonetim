@page "/sakin/talepler"

@attribute [Authorize(Roles = "Resident")]
@inject ISiteManagementService SiteService
@inject ISiteResidentService ResidentService
@inject ISiteMaintenanceService MaintenanceService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Bakım Taleplerim</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudButton Href="/sakin" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Portal</MudButton>
        <MudText Typo="Typo.h5" Style="font-weight:700">Bakım Taleplerim</MudText>
        <MudSpacer />
        @if (_site is not null)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">Yeni Talep</MudButton>
        }
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_requests.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Henüz bakım talebiniz bulunmuyor.</MudAlert>
    }
    else
    {
        <MudTable T="MaintenanceRequestDto" Items="_requests" Dense="true" Hover="true" Elevation="1">
            <HeaderContent>
                <MudTh>Başlık</MudTh>
                <MudTh>Kategori</MudTh>
                <MudTh>Öncelik</MudTh>
                <MudTh>Durum</MudTh>
                <MudTh>Tarih</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Style="font-weight:500">@context.Title</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                </MudTd>
                <MudTd>@context.Category</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@PriorityColor(context.Priority)">@PriorityLabel(context.Priority)</MudChip>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@StatusLabel(context.Status)</MudChip>
                </MudTd>
                <MudTd>@context.ReportedAt.ToString("dd.MM.yyyy")</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    private bool _loading = true;
    private SiteDto? _site;
    private ResidentDto? _resident;
    private List<MaintenanceRequestDto> _requests = [];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        if (!Guid.TryParse(user.FindFirst("site_id")?.Value, out var siteId)) { _loading = false; return; }
        _site = await SiteService.GetByIdAsync(siteId);
        if (_site is null) { _loading = false; return; }
        _resident = await ResidentService.GetByUserIdAsync(_site.DbFilePath, userId);
        if (_resident is not null)
        {
            var all = await MaintenanceService.GetAllAsync(_site.DbFilePath);
            _requests = all.Where(req => req.UnitId == _resident.UnitId).ToList();
        }
        _loading = false;
    }

    private async Task OpenAddDialog()
    {
        var p = new DialogParameters<MaintenanceFormDialog>
        {
            { x => x.DbFilePath, _site!.DbFilePath },
        };
        var dialog = await DialogService.ShowAsync<MaintenanceFormDialog>("Yeni Bakım Talebi", p, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        if (!(await dialog.Result)!.Canceled)
        {
            Snackbar.Add("Bakım talebiniz iletildi.", Severity.Success);
            var all = await MaintenanceService.GetAllAsync(_site!.DbFilePath);
            _requests = all.Where(req => req.UnitId == _resident!.UnitId).ToList();
        }
    }

    private static Color PriorityColor(MaintenancePriority p) => p switch { MaintenancePriority.Urgent => Color.Error, MaintenancePriority.High => Color.Warning, MaintenancePriority.Low => Color.Default, _ => Color.Info };
    private static string PriorityLabel(MaintenancePriority p) => p switch { MaintenancePriority.Urgent => "Kritik", MaintenancePriority.High => "Yüksek", MaintenancePriority.Low => "Düşük", _ => "Normal" };
    private static Color StatusColor(MaintenanceStatus s) => s switch { MaintenanceStatus.Open => Color.Error, MaintenanceStatus.InProgress => Color.Warning, MaintenanceStatus.Resolved => Color.Success, _ => Color.Default };
    private static string StatusLabel(MaintenanceStatus s) => s switch { MaintenanceStatus.Open => "Açık", MaintenanceStatus.InProgress => "İşlemde", MaintenanceStatus.Resolved => "Çözüldü", _ => "İptal" };
}
