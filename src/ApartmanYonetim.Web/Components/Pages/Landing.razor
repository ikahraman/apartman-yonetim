@page "/"
@layout PublicLayout
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>ApartNet — Apartman & Site Yönetim Portalı</PageTitle>

@* ─── HOŞGELDIN BANDI ─────────────────────────────────────────────────────── *@
<div style="background:linear-gradient(90deg,#1565C0,#0D47A1);color:white;padding:20px 16px">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5" Style="font-weight:800">Apartman & Site Yönetim Portalı</MudText>
                <MudText Typo="Typo.body2" Style="opacity:0.85">KMK rehberi · Eğitim · Servis rehberi · Profesyonel yönetim sistemi</MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Login"
                       Href="/giris" Style="font-weight:700;white-space:nowrap">
                Yönetim Sistemine Giriş
            </MudButton>
        </MudStack>
    </MudContainer>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-5">
    <MudGrid Spacing="4">

        @* ─── ANA İÇERİK (Sol) ────────────────────────────────────────────── *@
        <MudItem xs="12" md="8">

            @* Son Haberler *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Newspaper" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Style="font-weight:700">Son Haberler & Duyurular</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Href="/haberler">Tümü →</MudButton>
            </MudStack>

            <MudStack Spacing="3" Class="mb-6">
                @foreach (var haber in _haberler)
                {
                    <MudPaper Elevation="1" Class="pa-4" Style="border-left:4px solid;border-color:var(--mud-palette-primary)">
                        <MudStack Spacing="1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudChip T="string" Size="Size.Small" Color="@haber.TagColor" Style="height:22px">@haber.Tag</MudChip>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@haber.Tarih</MudText>
                            </MudStack>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;cursor:pointer" Class="mud-primary-text">
                                @haber.Baslik
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@haber.Ozet</MudText>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>

            @* KMK Öne Çıkan *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Error" />
                <MudText Typo="Typo.h6" Style="font-weight:700">KMK Rehberi — Öne Çıkan Konular</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Href="/bilgi/hukuki-cerceve">Tümü →</MudButton>
            </MudStack>

            <MudGrid Spacing="3" Class="mb-2">
                @foreach (var konu in _kmkKonular)
                {
                    <MudItem xs="12" sm="6">
                        <MudCard Elevation="1" Style="cursor:pointer;height:100%">
                            <MudCardContent>
                                <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                                    <MudIcon Icon="@konu.Icon" Color="Color.Primary" Style="margin-top:2px" />
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600">@konu.Baslik</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@konu.Aciklama</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudItem>

        @* ─── KENAR ÇUBUĞU (Sağ) ─────────────────────────────────────────── *@
        <MudItem xs="12" md="4">

            @* Hızlı Erişim *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700" Class="mb-3">Hızlı Erişim</MudText>
                <MudStack Spacing="1">
                    @foreach (var link in _hizliErisim)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                   StartIcon="@link.Icon" Href="@link.Href"
                                   Style="justify-content:flex-start;text-transform:none">
                            @link.Label
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>

            @* Yönetim Sistemi Tanıtım *@
            <MudPaper Elevation="2" Class="pa-4 mb-4" Style="background:linear-gradient(135deg,#E3F2FD,#BBDEFB)">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700">Yönetim Sistemi</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2">Aidatlar, sakinler, arızalar, muhasebe ve duyurular — tek ekranda profesyonel yönetim.</MudText>
                    <MudStack Spacing="1">
                        @foreach (var m in new[] { "Çok bloklu site desteği", "Aidat takibi & tahakkuk", "Sakin portali", "Excel dışa aktarma" })
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                <MudText Typo="Typo.caption">@m</MudText>
                            </MudStack>
                        }
                    </MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               Href="/giris" StartIcon="@Icons.Material.Filled.Login" Style="font-weight:700">
                        Giriş Yap
                    </MudButton>
                </MudStack>
            </MudPaper>

            @* Yakında: Eğitim *@
            <MudPaper Elevation="2" Class="pa-4" Style="background:linear-gradient(135deg,#E8F5E9,#C8E6C9)">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Success" />
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700">Sertifikalı Eğitim</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Style="height:20px;font-size:10px">Yakında</MudChip>
                    </MudStack>
                    <MudText Typo="Typo.body2">Apartman yöneticileri ve yönetim firmaları için KMK kapsamlı online sertifika programı.</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.NotificationsActive" Style="text-transform:none">
                        Haberdar Ol
                    </MudButton>
                </MudStack>
            </MudPaper>

        </MudItem>
    </MudGrid>
</MudContainer>

@* ─── FOOTER ─────────────────────────────────────────────────────────────── *@
<div style="background:#212121;color:rgba(255,255,255,0.7);padding:32px 16px;margin-top:16px">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.h6" Style="color:white;font-weight:700" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Apartment" Class="mr-1" Style="vertical-align:middle" />
                    ApartNet
                </MudText>
                <MudText Typo="Typo.caption">Apartman & Site Yönetiminde Tek Adres</MudText>
            </MudItem>
            <MudItem xs="6" sm="4">
                <MudText Typo="Typo.subtitle2" Style="color:white" Class="mb-1">Platform</MudText>
                <MudStack Spacing="0">
                    @foreach (var (label, href) in new[] { ("KMK Rehberi", "/bilgi/hukuki-cerceve"), ("Eğitim", "/bilgi/egitim"), ("Servis Rehberi", "/bilgi/servis-rehberi"), ("Yönetim Sistemi", "/giris") })
                    {
                        <MudLink Href="@href" Typo="Typo.caption" Style="color:rgba(255,255,255,0.6)">@label</MudLink>
                    }
                </MudStack>
            </MudItem>
            <MudItem xs="6" sm="4">
                <MudText Typo="Typo.subtitle2" Style="color:white" Class="mb-1">İletişim</MudText>
                <MudText Typo="Typo.caption">info@apartnet.com.tr</MudText>
            </MudItem>
        </MudGrid>
        <MudDivider Class="my-3" Style="border-color:rgba(255,255,255,0.1)" />
        <MudText Typo="Typo.caption" Align="Align.Center">© @DateTime.Now.Year ApartNet. Tüm hakları saklıdır.</MudText>
    </MudContainer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            var user = auth.User;
            if (user.IsInRole("SuperAdmin")) Nav.NavigateTo("/admin/firmalar");
            else if (user.IsInRole("Resident") && !user.IsInRole("Manager") && !user.IsInRole("SiteStaff")) Nav.NavigateTo("/sakin");
            else Nav.NavigateTo("/sitelerim");
        }
    }

    private record Haber(string Tag, Color TagColor, string Tarih, string Baslik, string Ozet);
    private static readonly Haber[] _haberler =
    [
        new("KMK Değişikliği", Color.Error, "Ocak 2025",
            "Kat Mülkiyeti Kanunu'nda Yapılan Son Değişiklikler",
            "2025 yılı başında yürürlüğe giren düzenlemelerle birlikte site yönetiminde toplantı yeter sayıları ve aidat gecikme faizlerine ilişkin önemli değişiklikler hayata geçirildi."),
        new("Yargıtay Kararı", Color.Warning, "Kasım 2024",
            "Yargıtay: Aidat Borçlusu Kat Maliki Ortak Alandan Faydalanamaz",
            "Yargıtay 18. Hukuk Dairesi'nin emsal niteliğindeki kararına göre aidat borcunu ödemeyen kat maliki yönetim kurulu kararıyla ortak alan kullanımından kısıtlanabilir."),
        new("Rehber", Color.Primary, "Ekim 2024",
            "Site Yöneticisi Seçimi: Dikkat Edilmesi Gereken 7 Madde",
            "Kat malikleri kurulu toplantısında yönetici seçiminin yasal gereklilikleri, yeter sayılar ve yöneticinin görev süresi hakkında kapsamlı rehber."),
    ];

    private record KmkKonu(string Icon, string Baslik, string Aciklama);
    private static readonly KmkKonu[] _kmkKonular =
    [
        new(Icons.Material.Filled.Gavel, "Yönetici Sorumlulukları", "Madde 35-38: Yöneticinin yasal yükümlülükleri"),
        new(Icons.Material.Filled.AccountBalance, "Aidat Hukuku", "Ödeme yükümlülüğü, gecikme faizi ve hukuki yollar"),
        new(Icons.Material.Filled.Groups, "Kat Malikleri Kurulu", "Toplantı, yeter sayı ve karar alma usulleri"),
        new(Icons.Material.Filled.Build, "Ortak Alan Bakımı", "Gider paylaşımı ve bakım sorumluluğu"),
    ];

    private record HizliErisimLink(string Icon, string Label, string Href);
    private static readonly HizliErisimLink[] _hizliErisim =
    [
        new(Icons.Material.Filled.Gavel,       "KMK 634 Rehberi",        "/bilgi/hukuki-cerceve"),
        new(Icons.Material.Filled.Description,  "Hazır Şablonlar",        "/bilgi/sablonlar"),
        new(Icons.Material.Filled.School,       "Eğitim & Sertifika",     "/bilgi/egitim"),
        new(Icons.Material.Filled.Handyman,     "Servis Firmaları",       "/bilgi/servis-rehberi"),
        new(Icons.Material.Filled.QuestionAnswer,"Sık Sorulan Sorular",   "/bilgi/sss"),
        new(Icons.Material.Filled.SupportAgent, "Destek Talebi",          "/destek"),
    ];
}
