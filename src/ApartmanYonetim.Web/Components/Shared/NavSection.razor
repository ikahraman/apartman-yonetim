<div style="padding:12px 16px 2px; pointer-events:none; user-select:none">
    <MudText Typo="Typo.overline"
             Style="font-size:10px; font-weight:700; letter-spacing:1.5px; opacity:0.5; line-height:1">
        @Label
    </MudText>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
}
