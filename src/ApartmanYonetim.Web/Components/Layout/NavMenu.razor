<MudNavMenu>
    <AuthorizeView>
        <Authorized>

            <!-- ── Kullanıcı Bilgisi ───────────────────────── -->
            <div class="pa-3" style="background:var(--mud-palette-primary);color:#fff;margin-bottom:4px">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="font-weight:700;color:#fff">
                        @(context.User.FindFirst("DisplayName")?.Value ?? context.User.Identity?.Name ?? "Kullanıcı")
                    </MudText>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Style="border-color:rgba(255,255,255,.6);color:#fff;height:20px;font-size:10px">
                            @RoleLabel(context.User)
                        </MudChip>
                        @if (context.User.FindFirst("firm_slug")?.Value is { } slug)
                        {
                            <MudText Typo="Typo.caption" Style="opacity:.75;color:#fff">@slug</MudText>
                        }
                    </MudStack>
                </MudStack>
            </div>

            <!-- ── Ana Sayfa ───────────────────────────────── -->
            <a href="/" data-enhance-nav="false" style="display:flex;align-items:center;gap:8px;padding:8px 16px;color:inherit;text-decoration:none;border-radius:4px">
                <MudIcon Icon="@Icons.Material.Filled.Home" Color="Color.Primary" Size="Size.Small" />
                <span>Ana Sayfa</span>
            </a>

            <!-- ══ MANAGER ════════════════════════════════════ -->
            <AuthorizeView Roles="FirmAdmin" Context="_m">

                <NavSection Label="SİTELER" />
                <MudNavLink Href="/sitelerim" Icon="@Icons.Material.Filled.Apartment" IconColor="Color.Primary">
                    Sitelerim
                </MudNavLink>
                <MudNavLink Href="/firma/site-ekle" Icon="@Icons.Material.Filled.AddHome" IconColor="Color.Primary">
                    Yeni Site Ekle
                </MudNavLink>

                <NavSection Label="FİRMAM" />
                <MudNavLink Href="/firma/ozet" Icon="@Icons.Material.Filled.Dashboard" IconColor="Color.Secondary">
                    Genel Özet
                </MudNavLink>
                <MudNavLink Href="/firma/personel" Icon="@Icons.Material.Filled.People" IconColor="Color.Secondary">
                    Personel
                </MudNavLink>
                <MudNavLink Href="/firma/sozlesmeler" Icon="@Icons.Material.Filled.Assignment" IconColor="Color.Secondary">
                    Sözleşmeler
                </MudNavLink>
                <MudNavLink Href="/firma/faturalama" Icon="@Icons.Material.Filled.Receipt" IconColor="Color.Secondary">
                    Faturalama
                </MudNavLink>
                <MudNavLink Href="/firma/profil" Icon="@Icons.Material.Filled.Info" IconColor="Color.Default">
                    Firma Profili
                </MudNavLink>
            </AuthorizeView>

            <!-- ══ SiteManager / Auditor / Accountant ═══════════ -->
            <AuthorizeView Roles="SiteManager,Auditor,Accountant" Context="_s">
                <NavSection Label="SİTELER" />
                <MudNavLink Href="/sitelerim" Icon="@Icons.Material.Filled.Apartment" IconColor="Color.Primary">
                    Sitelerim
                </MudNavLink>
            </AuthorizeView>

            <!-- ══ Resident ════════════════════════════════════ -->
            <AuthorizeView Roles="Resident" Context="_r">
                <NavSection Label="SAKIN" />
                <MudNavLink Href="/sakin" Icon="@Icons.Material.Filled.Home" IconColor="Color.Primary">
                    Sakin Portali
                </MudNavLink>
            </AuthorizeView>

            <!-- ══ EGİTİM ADMİN ════════════════════════════════ -->
            <AuthorizeView Roles="EgitimAdmin,SuperAdmin" Context="_ea">
                <NavSection Label="EĞİTİM" />
                <MudNavLink Href="/egitim/admin" Icon="@Icons.Material.Filled.School" IconColor="Color.Secondary">
                    Eğitim Yönetimi
                </MudNavLink>
            </AuthorizeView>

            <!-- ══ SUPERADMIN ══════════════════════════════════ -->
            <AuthorizeView Roles="SuperAdmin" Context="_a">

                <NavSection Label="PLATFORM" />
                <MudNavLink Href="/admin/firmalar" Icon="@Icons.Material.Filled.Business" IconColor="Color.Primary">
                    Firmalar
                </MudNavLink>
                <MudNavLink Href="/admin/siteler" Icon="@Icons.Material.Filled.Apartment" IconColor="Color.Primary">
                    Tüm Siteler
                </MudNavLink>
                <MudNavLink Href="/admin/kullanicilar" Icon="@Icons.Material.Filled.People" IconColor="Color.Primary">
                    Kullanıcılar
                </MudNavLink>

                <NavSection Label="FİNANS" />
                <MudNavLink Href="/admin/fiyatlandirma" Icon="@Icons.Material.Filled.PriceChange" IconColor="Color.Warning">
                    Fiyatlandırma
                </MudNavLink>
                <MudNavLink Href="/admin/faturalar" Icon="@Icons.Material.Filled.AccountBalance" IconColor="Color.Warning">
                    Faturalar & Ödemeler
                </MudNavLink>
            </AuthorizeView>

        </Authorized>

        <NotAuthorized>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Ana Sayfa</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private static string RoleLabel(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.IsInRole("SuperAdmin"))  return "SuperAdmin";
        if (user.IsInRole("FirmAdmin"))    return "Yönetici";
        if (user.IsInRole("SiteManager"))   return "Personel";
        if (user.IsInRole("Accountant"))  return "Muhasebe";
        if (user.IsInRole("Auditor"))     return "Denetçi";
        if (user.IsInRole("Resident"))    return "Sakin";
        return "Kullanıcı";
    }
}
