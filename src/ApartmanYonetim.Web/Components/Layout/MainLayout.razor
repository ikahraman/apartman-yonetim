@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudOverlay Visible="_navigating" DarkBackground="true" ZIndex="9999" AutoClose="false">
    <MudStack AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Style="color:white">Sayfa açılıyor...</MudText>
    </MudStack>
</MudOverlay>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <a href="/" data-enhance-nav="false" style="font-weight:700;letter-spacing:-0.5px;font-size:1.25rem;color:inherit;text-decoration:none;display:flex;align-items:center">
            <MudIcon Icon="@Icons.Material.Filled.Apartment" Class="mr-1" Style="vertical-align:middle" />
            ApartNet
        </a>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2" Style="opacity:0.85">
                    @(context.User.FindFirst("DisplayName")?.Value ?? context.User.Identity?.Name ?? "")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               Href="/cikis" Title="Çıkış Yap" />
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/giris">Giriş</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-3 pa-sm-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _navigating;
    private IDisposable? _locationChangingHandler;

    protected override void OnInitialized()
    {
        _locationChangingHandler = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        Nav.LocationChanged += OnLocationChanged;
    }

    private ValueTask OnLocationChanging(LocationChangingContext ctx)
    {
        _navigating = true;
        InvokeAsync(StateHasChanged);
        return ValueTask.CompletedTask;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _navigating = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _locationChangingHandler?.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
